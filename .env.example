## ---------- Public Environment Variables ----------
NEXT_PUBLIC_CURRENCY=$

# Mongodb
MONGODB_URI='-------- MongoDB URI --------'

# Clerk
CLERK_SECRET_KEY='-------- Clerk Secret Key --------'
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='-------- Clerk Publishable Key --------'

# Inngest Setup
INNGEST_SIGNING_KEY='-------- Inngest Signing Key --------'
INNGEST_EVENT_KEY='-------- Inngest Event Key --------'

# Cloudinary
CLOUDINARY_CLOUD_NAME='-------- Cloud Name --------'
CLOUDINARY_API_KEY='-------- API Key --------'
CLOUDINARY_API_SECRET='-------- API Secret --------'

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID='------- Key ID -------'
RAZORPAY_KEY_ID='------- Key ID -------'
RAZORPAY_KEY_SECRET='------- Key Secret -------'

# ---------- Admin Setup (one-time) ----------
# 1. Create a Clerk account with any email (e.g. admin@quickcart.com) via the Clerk dashboard.
# 2. In Clerk Dashboard → Users → select the account → Public Metadata, set:
#    { "role": "admin" }
# 3. That user can now log in at /sign-in and will be redirected to /admin/dashboard.
# No hardcoded password — all auth is handled by Clerk.
