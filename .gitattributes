# Set the default behavior to automatically normalize line endings to LF on commit
* text=auto eol=lf

# Force specific text files to keep LF
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.env text eol=lf
.env.example text eol=lf
